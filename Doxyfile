PROJECT_NAME           = "Corporate System Architecture"
OUTPUT_DIRECTORY       = docs

# --- SCANNING ---
INPUT                  = .
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.hpp *.h
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = .

# --- EXCLUSIONS ---
EXCLUDE                = build .git docs tests node_modules
EXCLUDE_PATTERNS       = */test/* */external/*

# --- EXTRACTION ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# --- DIAGRAM SETTINGS ---
HAVE_DOT               = YES
UML_LOOK               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

# --- OUTPUTS ---
GENERATE_XML           = YES
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
XML_PROGRAMLISTING     = NO